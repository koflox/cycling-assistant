# Secrets and API Keys - Example Template
# Copy this file to secrets.properties and add your actual API keys.
# secrets.properties is git-ignored.

# Google Maps API Key.
# Get your API key from: https://console.cloud.google.com/
# Enable "Maps SDK for Android" for your project.
MAPS_API_KEY=YOUR_API_KEY_HERE

# Strava OAuth client credentials.
# Register an application at: https://www.strava.com/settings/api
# - "Authorization Callback Domain" must be: koflox.github.io
#   (the redirect URI is cyclingassistant://koflox.github.io/strava/callback)
# - "Website" can be any valid URL
# New apps are limited to 1 connected athlete by default; request a quota
# increase from the Strava developer console once the app is ready for users.
# See docs/features/strava-sync.md for the full integration overview.
STRAVA_CLIENT_ID=YOUR_CLIENT_ID_HERE
STRAVA_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
